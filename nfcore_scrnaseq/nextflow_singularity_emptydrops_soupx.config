/*
 * nf-core/scrnaseq configuration for local HPC
 *
 * Configuration: EmptyDrops + SoupX (No CellBender)
 * Purpose: Cell filtering with EmptyDrops + contamination removal with SoupX
 *
 * Status: Testing
 * Note: This configuration combines EmptyDrops statistical filtering with
 *       SoupX lightweight contamination removal, skipping the GPU-intensive
 *       CellBender deep learning denoising.
 */

params {
    // Input/Output
    input = 'samplesheet.csv'
    outdir = 'results_nfcore_emptydrops_soupx'

    // Reference files
    fasta = '/data/salomonis-archive/genomes/spaceranger_ref/refdata-gex-GRCh38-2020-A/fasta/genome.fa'
    gtf = '/data/salomonis-archive/genomes/spaceranger_ref/refdata-gex-GRCh38-2020-A/genes/genes.gtf'
    transcript_fasta = ''

    // Alevin-specific parameters
    aligner = 'alevin'
    protocol = '10XV3'
    simpleaf_rlen = 91

    // ========================================================================
    // FILTERING STRATEGY: SoupX ONLY (No CellBender/EmptyDrops)
    // ========================================================================
    // NOTE: In nf-core/scrnaseq, CellBender IS the EmptyDrops implementation.
    //       They are the same thing. Cannot have "EmptyDrops without CellBender".
    //       Colleague request: "No CellBender needed, only SoupX"
    //       → Solution: Skip both with skip_emptydrops = true

    // EmptyDrops/CellBender: DISABLED (because CellBender = EmptyDrops in this pipeline)
    // Reason: Colleague explicitly requested "No CellBender"
    //         CellBender performs EmptyDrops; they're not separate
    //         Using lightweight SoupX contamination removal instead
    skip_emptydrops = true

    // SoupX: ENABLED (default)
    // Purpose: Lightweight contamination removal for ambient RNA
    skip_soupx = false

    // ========================================================================
    // OUTPUT FORMAT & QUALITY CONTROL
    // ========================================================================

    // Save reference genome for reuse
    save_reference = true

    // Output formats
    // MTX: Matrix Market (standard sparse format)
    // H5AD: HDF5 AnnData (Python compatible)
    // Seurat: R Seurat object

    // ========================================================================
    // RESOURCE ALLOCATION
    // ========================================================================

    max_cpus = 8
    max_memory = '64.GB'
    max_time = '8.h'
}

// ============================================================================
// PROCESS CONFIGURATION (Singularity containers)
// ============================================================================

process {
    executor = 'local'
    container = 'nfcore/scrnaseq:3.0.0'

    // Standard process labels
    withLabel: process_low {
        cpus = 2
        memory = '8.GB'
        time = '2.h'
    }

    withLabel: process_medium {
        cpus = 4
        memory = '16.GB'
        time = '4.h'
    }

    withLabel: process_high {
        cpus = 8
        memory = '32.GB'
        time = '6.h'
    }
}

// ============================================================================
// SINGULARITY CONFIGURATION
// ============================================================================

singularity {
    enabled = true
    autoMounts = true
    cacheDir = '.singularity_cache'
}

// ============================================================================
// NEXTFLOW CONFIGURATION
// ============================================================================

nextflow {
    version = '>=22.10'
}

// ============================================================================
// EXECUTION PROFILE
// ============================================================================

manifest {
    name = 'nf-core/scrnaseq'
    author = 'nf-core/scrnaseq contributors'
    homePage = 'https://github.com/nf-core/scrnaseq'
    description = 'nf-core/scrnaseq: Nextflow pipeline for preprocessing scRNA-seq data'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10'
    version = '3.0.0'
}

// ============================================================================
// NOTES FOR TESTING
// ============================================================================

/*
CRITICAL CLARIFICATION (Feb 16 16:15):
In nf-core/scrnaseq v3.0.0:
- CellBender IS the implementation of EmptyDrops filtering
- They are NOT separate options
- Parameter: skip_emptydrops = true/false (controls CellBender, not R EmptyDrops)
- Cannot have "EmptyDrops filtering without CellBender" in this pipeline

SOLUTION: Per colleague request "No CellBender needed, only SoupX"
- Set: skip_emptydrops = true (skips CellBender/EmptyDrops)
- Set: skip_soupx = false (runs SoupX contamination removal)
- Result: SoupX-only filtering (lightweight, CPU-only, no permission issues)

TESTING THIS CONFIGURATION:
1. Run with LSF: submit_nfcore_emptydrops_soupx_lsf.sh
2. Expected runtime: 25-30 minutes (no CellBender = 3-4× faster)
3. Expected output cells: ~7,500 (SoupX filtering, no CellBender EmptyDrops)
4. Success criteria:
   - No Singularity permission errors
   - SoupX contamination removal completes
   - All output files generated (MTX, H5AD, etc.)
   - Matches Phase 1 SoupX-only results (7,498 cells)

JOB HISTORY:
- Job 8878536 (Feb 16 15:13): Killed at 16:15 after running 1hr
  - Had skip_emptydrops=false → CellBender ran to epoch 049
  - Corrected: Now using skip_emptydrops=true

TROUBLESHOOTING:
- If CellBender still runs: Verify skip_emptydrops is set to true
- If SoupX fails: Check Python environment in container
- For RNA velocity: Output includes spliced/unspliced counts (USA mode)
*/
